        "dataCategory": "Time",
        "lineageTag": "62e3e484-d26f-4c64-9d2c-4cdddba85e55",
        "partitions": [
          {
            "name": "d_Calendario",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "ADDCOLUMNS (",
                "    // Cria automaticamente as datas do primeiro dia da primeira venda logada até o último",
                "    CALENDARAUTO(),",
                "    \"Ano\", YEAR([Date]),",
                "    \"Mês Abrev\", FORMAT([Date], \"MMM\"),",
                "    \"Mês Num\", MONTH([Date]),",
                "    \"Trimestre\", \"T\" & FORMAT([Date], \"Q\"),",
                "    \"Ano-Mês\", FORMAT([Date], \"YYYY-MM\")",
                ")",
                ""
              ],
              "type": "calculated"
            }
          }
        ]
      },
      {
        "name": "_Medidas",
        "annotations": [
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "columns": [
          {
            "name": "Coluna 1",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "35dfd9b0-f6f9-40e1-a0e3-fad28b51b4d3",
            "sourceColumn": "Coluna 1",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "a3b326e0-6c00-4314-8689-05f7a2deb24d",
        "measures": [
          {
            "name": "Total Sales",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": "SUM(f_Vendas[Sales])",
            "formatString": "\"R$\"\\ #,0.###############;-\"R$\"\\ #,0.###############;\"R$\"\\ #,0.###############",
            "lineageTag": "8b6bdbbe-84de-43ec-aae5-6bf9041197bd"
          },
          {
            "name": "Total Profit",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": "SUM(f_Vendas[Order Profit Per Order])",
            "formatString": "\"R$\"\\ #,0.###############;-\"R$\"\\ #,0.###############;\"R$\"\\ #,0.###############",
            "lineageTag": "edd1a484-89c4-4ac7-9c41-d10bd9018ce1"
          },
          {
            "name": "Total Orders",
            "expression": "DISTINCTCOUNT(f_Vendas[Order Id])",
            "formatString": "0",
            "lineageTag": "9f9a8544-284c-44ab-a5d1-85baee066a2c"
          },
          {
            "name": "Ticket Medio",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": "DIVIDE([Total Sales], [Total Orders], 0)",
            "formatString": "\"R$\"\\ #,0.00;-\"R$\"\\ #,0.00;\"R$\"\\ #,0.00",
            "lineageTag": "5f0f150c-f5a2-4eca-9dbd-f0e27d1a2c3b"
          },
          {
            "name": "Margem Lucro %",
            "expression": "DIVIDE([Total Profit], [Total Sales], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "18aedcdd-ac2c-473e-8ce6-04b434e1e81f"
          },
          {
            "name": "Desconto Medio %",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR vTotalDiscount = SUM(f_Vendas[Order Item Discount])",
              "RETURN DIVIDE(vTotalDiscount, [Total Sales], 0)",
              ""
            ],
            "lineageTag": "d36f9e09-a832-4b13-b5c9-9b7edc5366b7"
          },
          {
            "name": "Rank Produtos",
            "expression": "RANKX(ALL(d_Produto[Product Name]), [Total Sales], , DESC, Dense)",
            "formatString": "0",
            "lineageTag": "69e083a1-4bb1-4579-b443-849fd437fd90"
          },
          {
            "name": "Sales YTD",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": "CALCULATE([Total Sales], DATESYTD(d_Calendario[Date]))",
            "formatString": "\"R$\"\\ #,0.###############;-\"R$\"\\ #,0.###############;\"R$\"\\ #,0.###############",
            "lineageTag": "d43d38ae-809d-4dd1-a4fd-65c1594bdbdc"
          },
          {
            "name": "Sales Last Year",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": "CALCULATE([Total Sales], SAMEPERIODLASTYEAR(d_Calendario[Date]))",
            "formatString": "\"R$\"\\ #,0.###############;-\"R$\"\\ #,0.###############;\"R$\"\\ #,0.###############",
            "lineageTag": "d981e76b-736e-44f3-bbdb-2004022d0eb6"
          },
          {
            "name": "Crescimento YoY %",
            "expression": [
              "",
              "VAR vSalesLY = [Sales Last Year]",
              "RETURN DIVIDE([Total Sales] - vSalesLY, vSalesLY, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "7e6c25c2-2df8-4000-a6c5-de64acf2c649"
          },
          {
            "name": "Pedidos Atrasados",
            "expression": "CALCULATE([Total Orders], f_Vendas[Late_delivery_risk] = 1)",
            "formatString": "0",
            "lineageTag": "e5e45e44-dc03-4e37-ba0a-656e2fb73cf9"
          },
          {
            "name": "Taxa de Atrasos %",
            "expression": "DIVIDE([Pedidos Atrasados], [Total Orders], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "0aabed38-9861-47e8-98c3-41339aa6c0bc"
          },
          {
            "name": "Tempo Medio Entrega (Dias)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE(f_Vendas[Days for shipping (real)])",
            "lineageTag": "81dba403-619d-4e53-974d-dc433f8cd1d7"
          },
          {
            "name": "Faturamento Acumulado Pareto",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"pt-BR\"}"
              }
            ],
            "expression": [
              "",
              "VAR FaturamentoAtual = [Total Sales]",
              "RETURN",
              "CALCULATE(",
              "    [Total Sales],",
              "    FILTER(",
              "        ALLSELECTED('d_Produto'[Nome da Categoria]),",
              "        [Total Sales] >= FaturamentoAtual",
              "    )",
              ")",
              ""
            ],
            "formatString": "\"R$\"\\ #,0.###############;-\"R$\"\\ #,0.###############;\"R$\"\\ #,0.###############",
            "lineageTag": "871e3dcf-d342-4dc1-a8cb-a123d8c09991"
          },
          {
            "name": "% Acumulado Pareto",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "DIVIDE(",
              "    [Faturamento Acumulado Pareto],",
              "    CALCULATE([Total Sales], ALLSELECTED('d_Produto'[Nome da Categoria]))",
              ")",
              ""
            ],
            "lineageTag": "30be0df9-577f-42e3-bd49-9560d2ea573c"
          },
          {
            "name": "Média Dias Real",
            "expression": [
              "AVERAGE(f_Vendas[Days for shipping (real)])",
              ""
            ],
            "formatString": "0",
            "lineageTag": "5d677952-eb8f-4c58-b15f-fd7c02de0c31"
          },
          {
            "name": "Média Dias Programado",
            "expression": "AVERAGE(f_Vendas[Days for shipment (scheduled)])",
            "formatString": "0",
            "lineageTag": "3b3dc1e6-13de-47c1-9eec-581cdd830473"
          },
          {
            "name": "Diferença de Entrega (Atraso)",
            "expression": "[Média Dias Real] - [Média Dias Programado]",
            "formatString": "0",
            "lineageTag": "dd47aaf0-1d0d-4d73-a614-64f32acd31d9"
          }
        ],
        "partitions": [
          {
            "name": "_Medidas",
