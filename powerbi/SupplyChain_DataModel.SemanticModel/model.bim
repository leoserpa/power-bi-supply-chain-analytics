        "lineageTag": "3a670bf2-baaf-44c8-932e-eef932fdb004",
        "partitions": [
          {
            "name": "d_Loja",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = _DataCoOriginal,",
                "    ColunasSelecionadas = Table.SelectColumns(Fonte,{\"Department Id\", \"Department Name\", \"Latitude\", \"Longitude\"}),",
                "    RemoveDuplicadas = Table.Distinct(ColunasSelecionadas, {\"Department Id\"}),",
                "    TipoAlterado = Table.TransformColumnTypes(RemoveDuplicadas,{{\"Department Id\", Int64.Type}}),",
                "    #\"Duplicatas Removidas\" = Table.Distinct(TipoAlterado, {\"Department Id\"}),",
                "",
                "    // 🚀 TRADUÇÃO: Criando a coluna de Nome do Departamento em Português",
                "    TraduzirDepartamento = Table.AddColumn(#\"Duplicatas Removidas\", \"Nome do Departamento\", each ",
                "        if [Department Name] = \"Apparel\" then \"Vestuário\"",
                "        else if [Department Name] = \"Book Shop\" then \"Livraria\"",
                "        else if [Department Name] = \"Discs Shop\" then \"Loja de Discos\"",
                "        else if [Department Name] = \"Fan Shop\" then \"Loja de Artigos Esportivos\"",
                "        else if [Department Name] = \"Fitness\" then \"Fitness / Academia\"",
                "        else if [Department Name] = \"Footwear\" then \"Calçados\"",
                "        else if [Department Name] = \"Golf\" then \"Golfe\"",
                "        else if [Department Name] = \"Health and Beauty\" then \"Saúde e Beleza\"",
                "        else if [Department Name] = \"Outdoors\" then \"Ar Livre / Camping\"",
                "        else if [Department Name] = \"Pet Shop\" then \"Pet Shop\"",
                "        else if [Department Name] = \"Technology\" then \"Tecnologia\"",
                "        else [Department Name], type text)",
                "in",
                "    TraduzirDepartamento"
              ],
              "type": "m"
            }
          }
        ]
      },
