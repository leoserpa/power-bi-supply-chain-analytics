            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "46b39306-7e43-49cf-ac75-35ad7f2ca66b",
            "sourceColumn": "Shipping Mode",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "28ed4c14-2468-418f-8b5b-a1e222dbe0ab",
        "partitions": [
          {
            "name": "f_Vendas",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = _DataCoOriginal,",
                "    ColunasSelecionadas = Table.SelectColumns(Fonte,{\"Order Id\", \"Order Item Id\", \"Order Customer Id\", \"Order Item Cardprod Id\", \"Department Id\", \"order date (DateOrders)\", \"shipping date (DateOrders)\", \"Sales\", \"Order Item Total\", \"Order Profit Per Order\", \"Benefit per order\", \"Order Item Discount\", \"Order Item Quantity\", \"Days for shipping (real)\", \"Days for shipment (scheduled)\", \"Late_delivery_risk\", \"Order Status\", \"Delivery Status\", \"Shipping Mode\"}),",
                "    ",
                "    SepararDataPedido = Table.SplitColumn(ColunasSelecionadas, \"order date (DateOrders)\", Splitter.SplitTextByDelimiter(\" \", QuoteStyle.Csv), {\"Order Date\", \"Order Time\"}),",
                "    SepararDataEnvio = Table.SplitColumn(SepararDataPedido, \"shipping date (DateOrders)\", Splitter.SplitTextByDelimiter(\" \", QuoteStyle.Csv), {\"Shipping Date\", \"Shipping Time\"}),",
                "    RemoveHoras = Table.RemoveColumns(SepararDataEnvio,{\"Order Time\", \"Shipping Time\"}),",
                "",
                "    // CORREÇÃO CRÍTICA: Forçando o Power BI a ler Números e Datas no formato Americano (Ponto como decimal)",
                "    TransformacaoRegional = Table.TransformColumnTypes(RemoveHoras, {",
                "        {\"Order Date\", type date}, ",
                "        {\"Shipping Date\", type date},",
                "        {\"Sales\", Currency.Type},",
                "        {\"Order Item Total\", Currency.Type},",
                "        {\"Order Profit Per Order\", Currency.Type},",
                "        {\"Benefit per order\", Currency.Type},",
                "        {\"Order Item Discount\", Currency.Type}",
                "    }, \"en-US\"),",
                "",
                "    // Garantindo tipos inteiros para os IDs",
                "    TiposFinais = Table.TransformColumnTypes(TransformacaoRegional,{",
                "        {\"Order Id\", Int64.Type}, {\"Order Item Id\", Int64.Type}, {\"Order Customer Id\", Int64.Type}, {\"Order Item Cardprod Id\", Int64.Type}, {\"Department Id\", Int64.Type}, {\"Order Item Quantity\", Int64.Type}, {\"Late_delivery_risk\", Int64.Type}",
                "    })",
                "in",
                "    TiposFinais"
              ],
              "type": "m"
            }
          }
        ]
      },
