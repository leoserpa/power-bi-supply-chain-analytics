          {
            "name": "d_Produto",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = _DataCoOriginal,",
                "    ColunasSelecionadas = Table.SelectColumns(Fonte,{\"Product Card Id\", \"Category Id\", \"Category Name\", \"Product Name\", \"Product Price\", \"Product Status\"}),",
                "    RemoveDuplicadas = Table.Distinct(ColunasSelecionadas, {\"Product Card Id\"}),",
                "    // Ajusta IDs para Inteiro e Preço para Decimal Fixo (Moeda)",
                "    TipoAlterado = Table.TransformColumnTypes(RemoveDuplicadas,{{\"Product Card Id\", Int64.Type}, {\"Category Id\", Int64.Type}, {\"Product Price\", Currency.Type}}),",
                "    #\"Duplicatas Removidas\" = Table.Distinct(TipoAlterado, {\"Product Card Id\"})",
                "in",
                "    #\"Duplicatas Removidas\""
              ],
              "type": "m"
            }
          }
        ]
