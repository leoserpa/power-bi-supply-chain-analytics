        "lineageTag": "13fd13c3-b8a3-49d1-938b-0387ecd25773",
        "partitions": [
          {
            "name": "d_Produto",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = _DataCoOriginal,",
                "    ColunasSelecionadas = Table.SelectColumns(Fonte,{\"Product Card Id\", \"Category Id\", \"Category Name\", \"Product Name\", \"Product Price\", \"Product Status\"}),",
                "    RemoveDuplicadas = Table.Distinct(ColunasSelecionadas, {\"Product Card Id\"}),",
                "    // Ajusta IDs para Inteiro e Preço para Decimal Fixo (Moeda)",
                "    TipoAlterado = Table.TransformColumnTypes(RemoveDuplicadas,{{\"Product Card Id\", Int64.Type}, {\"Category Id\", Int64.Type}, {\"Product Price\", Currency.Type}}),",
                "    #\"Duplicatas Removidas\" = Table.Distinct(TipoAlterado, {\"Product Card Id\"}),",
                "",
                "    // 🚀 TRADUÇÃO COMPLETA: Injetando as 50 categorias traduzidas no seu código",
                "    TraduzirCategoria = Table.AddColumn(#\"Duplicatas Removidas\", \"Nome da Categoria\", each ",
                "        if [Category Name] = \"Accessories\" then \"Acessórios\"",
                "        else if [Category Name] = \"As Seen on  TV!\" then \"Visto na TV\"",
                "        else if [Category Name] = \"Baby \" then \"Bebê\"",
                "        else if [Category Name] = \"Baseball & Softball\" then \"Beisebol e Softbol\"",
                "        else if [Category Name] = \"Basketball\" then \"Basquete\"",
                "        else if [Category Name] = \"Books \" then \"Livros\"",
                "        else if [Category Name] = \"Boxing & MMA\" then \"Boxe e MMA\"",
                "        else if [Category Name] = \"CDs \" then \"CDs\"",
                "        else if [Category Name] = \"Cameras \" then \"Câmeras\"",
                "        else if [Category Name] = \"Camping & Hiking\" then \"Camping e Trilha\"",
                "        else if [Category Name] = \"Cardio Equipment\" then \"Equipamento Cardio\"",
                "        else if [Category Name] = \"Children's Clothing\" then \"Roupa Infantil\"",
                "        else if [Category Name] = \"Cleats\" then \"Chuteiras\"",
                "        else if [Category Name] = \"Computers\" then \"Computadores\"",
                "        else if [Category Name] = \"Consumer Electronics\" then \"Eletrônicos de Consumo\"",
                "        else if [Category Name] = \"Crafts\" then \"Artesanato\"",
                "        else if [Category Name] = \"DVDs\" then \"DVDs\"",
                "        else if [Category Name] = \"Electronics\" then \"Eletrônicos\"",
                "        else if [Category Name] = \"Fishing\" then \"Pesca\"",
                "        else if [Category Name] = \"Fitness Accessories\" then \"Acessórios de Fitness\"",
                "        else if [Category Name] = \"Garden\" then \"Jardim\"",
                "        else if [Category Name] = \"Girls' Apparel\" then \"Roupas de Menina\"",
                "        else if [Category Name] = \"Golf Apparel\" then \"Roupas de Golfe\"",
                "        else if [Category Name] = \"Golf Bags & Carts\" then \"Sacos e Carrinhos de Golfe\"",
                "        else if [Category Name] = \"Golf Balls\" then \"Bolas de Golfe\"",
                "        else if [Category Name] = \"Golf Gloves\" then \"Luvas de Golfe\"",
                "        else if [Category Name] = \"Golf Shoes\" then \"Sapatos de Golfe\"",
                "        else if [Category Name] = \"Health and Beauty \" then \"Saúde e Beleza\"",
                "        else if [Category Name] = \"Hockey\" then \"Hóquei\"",
                "        else if [Category Name] = \"Hunting & Shooting\" then \"Caça e Tiro\"",
                "        else if [Category Name] = \"Indoor/Outdoor Games\" then \"Jogos Internos/Externos\"",
                "        else if [Category Name] = \"Kids' Golf Clubs\" then \"Tacos de Golfe Infantil\"",
                "        else if [Category Name] = \"Lacrosse\" then \"Lacrosse\"",
                "        else if [Category Name] = \"Men's Clothing\" then \"Roupas Masculinas\"",
                "        else if [Category Name] = \"Men's Footwear\" then \"Calçados Masculinos\"",
                "        else if [Category Name] = \"Men's Golf Clubs\" then \"Tacos de Golfe Masculinos\"",
                "        else if [Category Name] = \"Music\" then \"Música\"",
                "        else if [Category Name] = \"Pet Supplies\" then \"Suprimentos para Pets\"",
                "        else if [Category Name] = \"Shop By Sport\" then \"Comprar por Esporte\"",
                "        else if [Category Name] = \"Soccer\" then \"Futebol\"",
                "        else if [Category Name] = \"Sporting Goods\" then \"Artigos Esportivos\"",
                "        else if [Category Name] = \"Strength Training\" then \"Treino de Força\"",
                "        else if [Category Name] = \"Tennis & Racquet\" then \"Tênis e Raquetes\"",
                "        else if [Category Name] = \"Toys\" then \"Brinquedos\"",
                "        else if [Category Name] = \"Trade-In\" then \"Troca/Usados\"",
                "        else if [Category Name] = \"Video Games\" then \"Vídeo Games\"",
                "        else if [Category Name] = \"Water Sports\" then \"Esportes Aquáticos\"",
                "        else if [Category Name] = \"Women's Apparel\" then \"Roupas Femininas\"",
                "        else if [Category Name] = \"Women's Clothing\" then \"Roupas Femininas\"",
                "        else if [Category Name] = \"Women's Golf Clubs\" then \"Tacos de Golfe Femininos\"",
                "        else [Category Name], type text)",
                "in",
                "    TraduzirCategoria"
              ],
              "type": "m"
            }
          }
        ]
      },
