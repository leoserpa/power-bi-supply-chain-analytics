          }
        ],
        "expression": [
          "let",
          "    // Aponte diretamente para o arquivo de 95MB, não para a pasta!",
          "    Fonte = Csv.Document(File.Contents(\"C:\\gogogo\\gogogo\\data\\DataCoSupplyChainDataset.csv\"),[Delimiter=\",\", Columns=53, Encoding=1252, QuoteStyle=QuoteStyle.None]),",
          "    // Promove a primeira linha a cabeçalho",
          "    PromoverCabecalho = Table.PromoteHeaders(Fonte, [PromoteAllScalars=true])",
          "in",
          "    PromoverCabecalho"
        ],
        "kind": "m",
        "lineageTag": "2452f070-0ea2-4da0-8020-0ec8eb5c1c81"
      }
