        "lineageTag": "063c1869-3848-4bef-9e7a-73a0afdf744a",
        "partitions": [
          {
            "name": "d_Cliente",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    // 1. Puxa os dados da consulta original",
                "    Fonte = _DataCoOriginal,",
                "    // 2. Seleciona apenas as colunas de cliente",
                "    ColunasSelecionadas = Table.SelectColumns(Fonte,{\"Customer Id\", \"Customer Fname\", \"Customer Lname\", \"Customer City\", \"Customer Country\", \"Customer Segment\", \"Customer State\", \"Customer Zipcode\"}),",
                "    // 3. Remove os clientes duplicados (deixa só 1 linha por cliente)",
                "    RemoveDuplicadas = Table.Distinct(ColunasSelecionadas, {\"Customer Id\"}),",
                "    // 4. Define o ID como Inteiro para otimizar a performance",
                "    TipoAlterado = Table.TransformColumnTypes(RemoveDuplicadas,{{\"Customer Id\", Int64.Type}}),",
                "    #\"Duplicatas Removidas\" = Table.Distinct(TipoAlterado, {\"Customer Id\"}),",
                "",
                "    // 🚀 TRADUÇÃO: Criando colunas amigáveis em Português",
                "    TraduzirSegmento = Table.AddColumn(#\"Duplicatas Removidas\", \"Segmento do Cliente\", each ",
                "        if [Customer Segment] = \"Consumer\" then \"Consumidor\"",
                "        else if [Customer Segment] = \"Corporate\" then \"Corporativo\"",
                "        else if [Customer Segment] = \"Home Office\" then \"Home Office\"",
                "        else [Customer Segment], type text),",
                "",
                "    TraduzirPais = Table.AddColumn(TraduzirSegmento, \"País\", each ",
                "        if [Customer Country] = \"Puerto Rico\" then \"Porto Rico\"",
                "        else if [Customer Country] = \"EE. UU.\" then \"EUA\"",
                "        else [Customer Country], type text)",
                "in",
                "    TraduzirPais"
              ],
              "type": "m"
            }
          }
        ]
      },
