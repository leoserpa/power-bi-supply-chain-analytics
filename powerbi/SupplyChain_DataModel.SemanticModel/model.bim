        "lineageTag": "28ed4c14-2468-418f-8b5b-a1e222dbe0ab",
        "partitions": [
          {
            "name": "f_Vendas",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Fonte = _DataCoOriginal,",
                "    ColunasSelecionadas = Table.SelectColumns(Fonte,{\"Order Id\", \"Order Item Id\", \"Order Customer Id\", \"Order Item Cardprod Id\", \"Department Id\", \"order date (DateOrders)\", \"shipping date (DateOrders)\", \"Sales\", \"Order Item Total\", \"Order Profit Per Order\", \"Benefit per order\", \"Order Item Discount\", \"Order Item Quantity\", \"Days for shipping (real)\", \"Days for shipment (scheduled)\", \"Late_delivery_risk\", \"Order Status\", \"Delivery Status\", \"Shipping Mode\", \"Market\", \"Order Region\"}),",
                "    ",
                "    SepararDataPedido = Table.SplitColumn(ColunasSelecionadas, \"order date (DateOrders)\", Splitter.SplitTextByDelimiter(\" \", QuoteStyle.Csv), {\"Order Date\", \"Order Time\"}),",
                "    SepararDataEnvio = Table.SplitColumn(SepararDataPedido, \"shipping date (DateOrders)\", Splitter.SplitTextByDelimiter(\" \", QuoteStyle.Csv), {\"Shipping Date\", \"Shipping Time\"}),",
                "    RemoveHoras = Table.RemoveColumns(SepararDataEnvio,{\"Order Time\", \"Shipping Time\"}),",
                "",
                "    TransformacaoRegional = Table.TransformColumnTypes(RemoveHoras, {",
                "        {\"Order Date\", type date}, ",
                "        {\"Shipping Date\", type date},",
                "        {\"Sales\", Currency.Type},",
                "        {\"Order Item Total\", Currency.Type},",
                "        {\"Order Profit Per Order\", Currency.Type},",
                "        {\"Benefit per order\", Currency.Type},",
                "        {\"Order Item Discount\", Currency.Type},",
                "        {\"Market\", type text},",
                "        {\"Order Region\", type text}",
                "    }, \"en-US\"),",
                "",
                "    // ✅ CORREÇÃO AQUI: Garanti que os dias de envio sejam reconhecidos como NÚMEROS",
                "    TiposFinais = Table.TransformColumnTypes(TransformacaoRegional,{",
                "        {\"Order Id\", Int64.Type}, ",
                "        {\"Order Item Id\", Int64.Type}, ",
                "        {\"Order Customer Id\", Int64.Type}, ",
                "        {\"Order Item Cardprod Id\", Int64.Type}, ",
                "        {\"Department Id\", Int64.Type}, ",
                "        {\"Order Item Quantity\", Int64.Type}, ",
                "        {\"Late_delivery_risk\", Int64.Type},",
                "        {\"Days for shipping (real)\", Int64.Type},",
                "        {\"Days for shipment (scheduled)\", Int64.Type}",
                "    }),",
                "",
                "    TraduzirStatusEntrega = Table.AddColumn(TiposFinais, \"Status de Entrega\", each ",
                "        if [Delivery Status] = \"Advance shipping\" then \"Envio Antecipado\"",
                "        else if [Delivery Status] = \"Late delivery\" then \"Entrega em Atraso\"",
                "        else if [Delivery Status] = \"Shipping on time\" then \"Entrega no Prazo\"",
                "        else if [Delivery Status] = \"Shipping canceled\" then \"Envio Cancelado\"",
                "        else [Delivery Status], type text),",
                "        ",
                "    TraduzirModoEnvio = Table.AddColumn(TraduzirStatusEntrega, \"Modo de Envio\", each ",
                "        if [Shipping Mode] = \"First Class\" then \"Primeira Classe\"",
                "        else if [Shipping Mode] = \"Second Class\" then \"Segunda Classe\"",
                "        else if [Shipping Mode] = \"Standard Class\" then \"Classe Padrão\"",
                "        else if [Shipping Mode] = \"Same Day\" then \"Mesmo Dia\"",
                "        else [Shipping Mode], type text),",
                "",
                "    TraduzirMercado = Table.AddColumn(TraduzirModoEnvio, \"Mercado\", each ",
                "        if [Market] = \"Africa\" then \"África\"",
                "        else if [Market] = \"Europe\" then \"Europa\"",
                "        else if [Market] = \"LATAM\" then \"América Latina\"",
                "        else if [Market] = \"Pacific Asia\" then \"Ásia-Pacífico\"",
                "        else if [Market] = \"USCA\" then \"EUA/Canadá\"",
                "        else [Market], type text),",
                "",
                "    TraduzirStatusPedido = Table.AddColumn(TraduzirMercado, \"Status do Pedido\", each ",
                "        if [Order Status] = \"COMPLETE\" then \"Concluído\"",
                "        else if [Order Status] = \"PENDING\" then \"Pendente\"",
                "        else if [Order Status] = \"PAID\" then \"Pago\"",
                "        else if [Order Status] = \"PROCESSING\" then \"Processando\"",
                "        else if [Order Status] = \"CANCELED\" then \"Cancelado\"",
                "        else if [Order Status] = \"CLOSED\" then \"Fechado\"",
                "        else if [Order Status] = \"ON_HOLD\" then \"Em Espera\"",
                "        else if [Order Status] = \"PENDING_PAYMENT\" then \"Pagamento Pendente\"",
                "        else if [Order Status] = \"PAYMENT_REVIEW\" then \"Revisão de Pagamento\"",
                "        else if [Order Status] = \"SUSPECTED_FRAUD\" then \"Suspeita de Fraude\"",
                "        else [Order Status], type text),",
                "",
                "    TraduzirRegiao = Table.AddColumn(TraduzirStatusPedido, \"Região do Pedido\", each ",
                "        if [Order Region] = \"Canada\" then \"Canadá\"",
                "        else if [Order Region] = \"Caribbean\" then \"Caribe\"",
                "        else if [Order Region] = \"Central Africa\" then \"África Central\"",
                "        else if [Order Region] = \"Central America\" then \"América Central\"",
                "        else if [Order Region] = \"Central Asia\" then \"Ásia Central\"",
                "        else if [Order Region] = \"East Africa\" then \"África Oriental\"",
                "        else if [Order Region] = \"East of USA\" then \"Leste dos EUA\"",
                "        else if [Order Region] = \"Eastern Asia\" then \"Ásia Oriental\"",
                "        else if [Order Region] = \"Eastern Europe\" then \"Europa Oriental\"",
                "        else if [Order Region] = \"North Africa\" then \"Norte da África\"",
                "        else if [Order Region] = \"Northern Europe\" then \"Norte da Europa\"",
                "        else if [Order Region] = \"Oceania\" then \"Oceania\"",
                "        else if [Order Region] = \"South America\" then \"América do Sul\"",
                "        else if [Order Region] = \"South Asia\" then \"Ásia do Sul\"",
                "        else if [Order Region] = \"South of  USA\" then \"Sul dos EUA\"",
                "        else if [Order Region] = \"Southeast Asia\" then \"Sudeste Asiático\"",
                "        else if [Order Region] = \"Southern Africa\" then \"África Austral\"",
                "        else if [Order Region] = \"Southern Europe\" then \"Sul da Europa\"",
                "        else if [Order Region] = \"US Center\" then \"Centro dos EUA\"",
                "        else if [Order Region] = \"West Africa\" then \"África Ocidental\"",
                "        else if [Order Region] = \"West Asia\" then \"Ásia Ocidental\"",
                "        else if [Order Region] = \"West of USA\" then \"Oeste dos EUA\"",
                "        else if [Order Region] = \"Western Europe\" then \"Europa Ocidental\"",
                "        else [Order Region], type text)",
                "in",
                "    TraduzirRegiao"
              ],
              "type": "m"
            }
          }
        ]
      },
